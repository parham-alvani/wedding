---
import { Icon } from "astro-icon/components";
import ContentSection from "~/components/content-section.astro";
import { type Guest } from "~/types";
import { config } from "astro.config";

export interface Props {
  guest: Guest;
}

const { guest } = Astro.props;
---

<ContentSection id="guest">
  <Fragment slot="lead">
    <p class="letter-pocket text-3xl">
      Dear {guest.name},<br />
      <br />
      We've planned the most special day of our life and we'd be thrilled to see
      you in our ceremony where we want to celebrate love<br />
      <br />
      Best, <br />
      Elahe & Parham
    </p>
    <h2
      class="gradient-text text-center font-extrabold tracking-tight text-3xl"
    >
      RSVP
    </h2>
    <h6 style="margin-top: -20px;">please kindly reply by Khordad 5th</h6>
    <fieldset class="flex w-4/6 flex-row text-lg">
      <div class="basis-1/2 text-center">
        <input
          type="radio"
          id="coming"
          name="coming"
          value="true"
          checked={guest.answer?.coming === true}
          disabled={guest.answer != null}
        />
        <label for="coming" class="text-secondary">Accept with pleasure</label>
        <br />
        <input
          type="radio"
          value="false"
          name="coming"
          id="not-coming"
          checked={guest.answer?.coming === false}
          disabled={guest.answer != null}
        />
        <label for="not-coming" class="text-secondary"
          >Decline with regret</label
        >
      </div>

      <div class="basis-1/2 text-center">
        <input
          type="checkbox"
          id="plus_one"
          name="plus_one"
          checked={guest.answer?.plus_one === true}
          disabled={guest.answer != null}
        />
        <label for="plus_one" class="text-secondary">Plus 1 adult</label>
      </div>
    </fieldset>
    <button
      data-id={guest.id}
      data-url={config.backend_public_url}
      id="submit"
      disabled={guest.answer != null}
      class="flex items-center justify-center gap-3"
    >
      {guest.answer == null ? "Respond to invitation" : "Already responded"}
      {
        guest.answer == null ? (
          <Icon name="mdi:love-letter-open" class="size-12" />
        ) : (
          <Icon name="mdi:love-letter" class="size-12" />
        )
      }
    </button>
  </Fragment>
</ContentSection>

<script>
  const submitBtn = document.getElementById("submit");
  if (submitBtn != null) {
    const id = submitBtn.getAttribute("data-id");
    const url = submitBtn.getAttribute("data-url");

    const submit = () => {
      const comingChk = document.getElementById("coming") as HTMLInputElement;
      const plusOneChk = document.getElementById(
        "plus_one"
      ) as HTMLInputElement;

      fetch(`${url}/guest/${id}/answer`, {
        method: "POST",
        body: JSON.stringify({
          coming: comingChk.value === "on",
          plus_one: plusOneChk.value === "on",
        }),
        headers: {
          "Content-Type": "application/json",
        },
      });
    };

    submitBtn.onclick = submit;
  }
</script>
