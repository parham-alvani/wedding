---
import { Icon } from "astro-icon/components";
import ContentSection from "~/components/content-section.astro";
import type { Guest } from "~/types";
import { wedding } from "~/wedding.config";

export interface Props {
  guest: Guest;
}

const { guest } = Astro.props;
const { husband, wife } = wedding.couple;
---

<ContentSection id="guest">
  <Fragment slot="pre-content">
    <p class="letter-pocket text-3xl">
      {
        guest.spouse_first_name == null
          ? `Dear ${guest.first_name},`
          : `Dear ${guest.first_name} & ${guest.spouse_first_name}`
      }
      <br />
      <br />
      &nbsp; We've planned the most special day of our life and we'd be thrilled to
      see you in our ceremony where we want to celebrate love<br />
      <br />
      Best, <br />
      {wife.name} & {husband.name}
    </p>
  </Fragment>
  {
    guest.is_family != true ? (
      <Fragment slot="lead">
        <h2 class="gradient-text text-center font-extrabold tracking-tight text-8xl">
          RSVP
        </h2>
        <fieldset class="mx-auto my-5 flex w-5/6 flex-row justify-center" aria-label="RSVP options">
          <div class="mx-5 flex basis-1/2 flex-col gap-5 text-left">
            <label>
              <input
                type="radio"
                id="coming"
                name="coming"
                value="true"
                checked={guest.answer?.coming === true}
                disabled={guest.answer != null}
              />
              Accept with pleasure
            </label>
            <label>
              <input
                type="radio"
                value="false"
                name="coming"
                id="not-coming"
                checked={guest.answer?.coming === false}
                disabled={guest.answer != null}
              />
              Decline with regret
            </label>
          </div>

          {guest.spouse_first_name == null ? (
            <div class="mx-5 basis-1/2 text-right">
              <input
                type="checkbox"
                id="plus_one"
                name="plus_one"
                checked={guest.answer?.plus_one === true}
                disabled={guest.answer != null}
              />
              <label for="plus_one">Plus 1 adult</label>
            </div>
          ) : (
            ""
          )}
        </fieldset>
        <button
          type="button"
          data-id={guest.id}
          id="submit"
          disabled={guest.answer != null}
          class="w-5/6 text-center lg:w-1/4"
          aria-label={guest.answer == null ? "Respond to invitation" : "Already responded"}
        >
          {guest.answer == null ? "Respond to invitation" : "Already responded"}
          {guest.answer == null ? (
            <Icon name="mdi:love-letter-open" class="inline size-12" />
          ) : (
            <Icon name="mdi:love-letter" class="inline size-12" />
          )}
        </button>
      </Fragment>
    ) : (
      ""
    )
  }
</ContentSection>

<script>
  const submitBtn = document.getElementById("submit");
  if (submitBtn != null) {
    const id = submitBtn.getAttribute("data-id");

    const submit = () => {
      const comingChk = document.getElementById("coming") as HTMLInputElement;
      const plusOneChk = document.getElementById(
        "plus_one",
      ) as HTMLInputElement;

      fetch(`/api/guest/${id}/answer`, {
        method: "POST",
        body: JSON.stringify({
          coming: comingChk.checked,
          plus_one: plusOneChk == null ? true : plusOneChk.checked, // when there is no plus one button, means we are on a couple page.
        }),
        headers: {
          "Content-Type": "application/json",
        },
      })
        .then((resp) => {
          if (!resp.ok) throw new Error("Failed to submit RSVP");
          window.location.reload();
        })
        .catch(() => {
          alert("Something went wrong. Please try again.");
        });
    };

    submitBtn.onclick = submit;
  }
</script>

<style>
  #submit {
    background-color: color-mix(in srgb, var(--color-primary) 50%, transparent);
    padding: 0.5rem;
    border-radius: 10px;
  }
</style>
