---
import { Icon } from "astro-icon/components";
import HeroImage from "~/components/hero-image.astro";
import type { FooterLink } from "~/types";

const parhamLinks: Array<FooterLink> = [
  {
    url: "https://github.com/elahe-dastan",
    description: "Parham Alvani's Github",
    icon: "mdi:github",
  },
  {
    url: "https://instagram.com/1995parham",
    description: "Parham Alvani's Instagram",
    icon: "fa-brands:instagram",
  },
];

const elaheLinks: Array<FooterLink> = [
  {
    url: "https://github.com/elahe-dastan",
    description: "Parham Alvani's Github",
    icon: "mdi:github",
  },
  {
    url: "https://instagram.com/elahe.dstn",
    description: "Elahe Dastan's Instagram",
    icon: "fa-brands:instagram",
  },
];
---

<footer class="relative flex h-64 items-center justify-center">
  <div class="absolute inset-0 overflow-hidden opacity-40">
    <HeroImage />
  </div>
  <ul class="relative grid grid-cols-2 gap-4">
    {
      parhamLinks.map((link) => (
        <li>
          <a
            class="flex size-16 items-center justify-center rounded-full border-2 border-current p-4"
            href={link.url}
          >
            <span class="sr-only">{link.description}</span>
            <Icon class="size-full" name={link.icon} />
          </a>
        </li>
      ))
    }
  </ul>
  <div class="grid grid-cols-2 gap-40"></div>
  <ul class="relative grid grid-cols-2 gap-4">
    {
      elaheLinks.map((link) => (
        <li>
          <a
            class="flex size-16 items-center justify-center rounded-full border-2 border-current p-4"
            href={link.url}
          >
            <span class="sr-only">{link.description}</span>
            <Icon class="size-full" name={link.icon} />
          </a>
        </li>
      ))
    }
  </ul>
</footer>
